---
import { Icon } from "astro-icon/components";
import { storyblokEditable, renderRichText } from "@storyblok/astro";
import { COPYRIGHT } from "../utils/utils";

const { winner, index, cardHeadlineTag = "h2" } = Astro.props;
const renderedRichText = renderRichText(winner.content);

const HeadlineTag = cardHeadlineTag;
---

<article
  {...storyblokEditable(winner)}
  class="bg-stone-100 p-6 mx-auto gap-6 grid md:gap-8 md:max-w-none md:grid-cols-2"
>
  <div class="relative">
    <img
      class="object-cover object-center w-full rounded float-left"
      src={`${winner.image.filename}/m/460x0/filters:quality(70):format(webp)`}
      srcset={`
        ${winner.image.filename}/m/400x0/filters:quality(70):format(webp) 400w,
        ${winner.image.filename}/m/690x0/filters:quality(70):format(webp) 690w,
        ${winner.image.filename}/m/920x0/filters:quality(70):format(webp) 920w
      `}
      sizes="auto, (max-width: 767px) 100vw, (max-width: 1023px) 50vw, 460px"
      width="460"
      height="460"
      loading="lazy"
      decoding="async"
      alt={winner.image.alt}
    />
    {
      !!winner.image.copyright && (
        <div class="absolute text-sm text-white right-2">
          {`${COPYRIGHT} ${winner.image.copyright}`}
        </div>
      )
    }
  </div>
  <div class="py-4">
    <HeadlineTag
      class="text-2xl md:text-2xl font-heading text-accent font-extrabold mb-3"
    >
      <Icon
        name={`tabler:number-${index}-small`}
        class="w-10 h-10 inline-block -mt-1 -ml-3 -mr-1"
        aria-hidden="true"
      />
      {winner.title}
    </HeadlineTag>
    {renderedRichText && <div set:html={renderedRichText} class="mb-1" />}
  </div>
</article>
