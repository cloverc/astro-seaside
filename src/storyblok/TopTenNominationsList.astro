---
import { storyblokEditable, useStoryblokApi } from "@storyblok/astro";
import Nominee from "./Nominee.astro";
import HeroText from "../components/HeroText.astro";
import Link from "../components/Link.astro";

const { blok } = Astro.props;

const yearMatch = Astro.url.pathname.match(/(\d{4})/);
const year = yearMatch ? yearMatch[0] : new Date().getFullYear();

const storyblokApi = useStoryblokApi();

const { data } = await storyblokApi.get("cdn/stories", {
  version: import.meta.env.DEV ? "draft" : "published",
  starts_with: `bucket-spade-list/vote-for-${year}-winners/`,
  is_startpage: false,
  sort_by: "created_at:asc",
});

const nominees = data.stories;
---

<section
  class="mx-auto sm:px-6 lg:py-20 max-w-7xl px-6 py-12 sm:py-16"
  {...storyblokEditable(blok)}
>
  <HeroText
    tagline="Bucket & Spade List"
    title={`Vote for the ${year} Bucket and Spade list`}
    subtitle={`Voting is now open for the ${year} Bucket and Spade top seaside experiences. Choose from the shortlist of seaside favourites and cast your vote.`}
  />
  <div class="m-neg32 mb-12 flex flex-row justify-center">
    <Link href="https://bit.ly/bucketspade2025vote" target="_blank">
      Vote Now
    </Link>
  </div>
  <ul>
    {
      nominees?.length &&
        nominees.map((nominee: any) => {
          nominee.content.slug = nominee.slug;
          return (
            <li class="rounded mb-12 md:mb-20 p-6 bg-card">
              <Nominee nominee={nominee.content} slug={nominee.slug} />
            </li>
          );
        })
    }
  </ul>
  <div class="flex flex-row justify-center">
    <Link href="https://bit.ly/bucketspade2025vote" target="_blank">
      Vote Now
    </Link>
  </div>
</section>
