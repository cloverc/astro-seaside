---
import { ClientRouter } from "astro:transitions";
import "../assets/styles/tailwind.css";
import CustomStyles from "../components/CustomStyles.astro";
import BasicScripts from "../components/BasicScripts.astro";

const { metadata } = Astro.props;

const siteTitle: string = metadata.siteTitle;
const pageTitle: string = metadata.pageTitle;
const description: string =
  metadata.description ||
  "Discover the rich heritage of seaside tourism and its unique architectural legacy with the Seaside Heritage Network.";

const titleText = `${pageTitle} - ${siteTitle}`;
---

<!doctype html>
<html lang="en" class="2xl:text-[20px]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/kameron-latin-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-latin-600-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="image"
      href="https://a.storyblok.com/f/251170/4298x3047/4582369638/penzanze-jubilee-pool.jpg/m/768x0/filters:quality(70):format(webp)"
      imagesrcset="https://a.storyblok.com/f/251170/4298x3047/4582369638/penzanze-jubilee-pool.jpg/m/400x0/filters:quality(70):format(webp) 400w, https://a.storyblok.com/f/251170/4298x3047/4582369638/penzanze-jubilee-pool.jpg/m/768x0/filters:quality(70):format(webp) 768w"
      imagesizes="(max-width: 1023px) 100vw, 60vw"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{titleText}</title>
    <meta name="description" content={description} />
    <CustomStyles />
    <ClientRouter />
  </head>

  <body class="antialiased text-default bg-page flex flex-col min-h-screen">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-primary focus:rounded focus:shadow-lg"
    >
      Skip to main content
    </a>
    <BasicScripts />
    <slot />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
